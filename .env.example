# 后端高德 Web 服务 Key（地理编码 + 路径规划）
AMAP_KEY=your_amap_web_service_key

# 高德路径规划请求配置
AMAP_ROUTE_TIMEOUT_MS=15000
AMAP_ROUTE_RETRY_COUNT=5

# 可选：服务器无法直连高德时，为后端容器配置代理
HTTP_PROXY=
HTTPS_PROXY=
NO_PROXY=postgres,localhost,127.0.0.1

# 前端高德 JS API Key（地图加载）
VITE_AMAP_KEY=your_amap_js_api_key

# 钉钉导出相关配置
DINGTALK_EXPORT_CHAT_ID=
DINGTALK_EXPORT_ROBOT_WEBHOOK=
DINGTALK_EXPORT_ROBOT_SECRET=
