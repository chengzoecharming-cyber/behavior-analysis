PORT=3000
DATABASE_URL=postgresql://sales:sales123@localhost:5433/sales_map
AMAP_KEY=YOUR_AMAP_KEY

# 里程读数合理上限（km），超过此值的读数会被视为异常
MILEAGE_VALIDATION_MAX_KM=5000

# 登录账号密码（临时硬编码，后续接入统一身份认证）
AUTH_USERNAME=admin
AUTH_PASSWORD=admin123

# 钉钉开放平台（企业内部应用）
DINGTALK_APP_KEY=YOUR_DINGTALK_APP_KEY
DINGTALK_APP_SECRET=YOUR_DINGTALK_APP_SECRET
DINGTALK_PROCESS_CODE=YOUR_DINGTALK_PROCESS_CODE

# 控制台导出报告目标钉钉群 chatid（可通过钉钉 JSAPI 选择群聊获取）
DINGTALK_EXPORT_CHAT_ID=

# 可选：自定义机器人 webhook，用于发送文字摘要（不填则不发送）
DINGTALK_EXPORT_ROBOT_WEBHOOK=

# 可选：自定义机器人加签密钥（如果机器人在钉钉里开了“加签”安全设置，需要填这个）
DINGTALK_EXPORT_ROBOT_SECRET=
